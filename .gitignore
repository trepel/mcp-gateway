# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
*.DS_Store

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov
out/

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
.idea/
.vscode/

.specstory
.cursorindexingignore
/bin/

# Ignore Python bytecode cache
**/__pycache__/

# Ignore personal TODO lists
TODO
local/
docs/plans/

# Generated OLM catalog artifacts
catalog/mcp-gateway-catalog/
catalog/mcp-gateway-catalog.Dockerfile
tests/perf/mock-server/mock-server

# Generated e2e config files (generated from *.template files)
config/e2e/gateway-1.yaml
config/e2e/gateway-2.yaml
config/e2e/gateway-shared.yaml
config/e2e/kustomization.yaml
