---
# Shared Gateway for multi-team isolation testing via sectionName
# This gateway has separate listener pairs for team-a and team-b
apiVersion: gateway.networking.k8s.io/v1
kind: Gateway
metadata:
  labels:
    istio: ingressgateway
    gateway.io/name: shared-gateway
  name: shared-gateway
  namespace: gateway-system
spec:
  gatewayClassName: ${GATEWAY_CLASS_NAME}
  listeners:
    # Team A listeners
    - name: team-a-mcp
      hostname: 'team-a.${E2E_DOMAIN}'
      port: 8080
      protocol: HTTP
      allowedRoutes:
        namespaces:
          from: Selector
          selector:
            matchLabels:
              mcp-team: team-a
    - name: team-a-mcps
      port: 8080
      protocol: HTTP
      hostname: '*.team-a.mcp.local'
      allowedRoutes:
        namespaces:
          from: Selector
          selector:
            matchLabels:
              mcp-team: team-a
    # Team B listeners
    - name: team-b-mcp
      hostname: 'team-b.${E2E_DOMAIN}'
      port: 8081
      protocol: HTTP
      allowedRoutes:
        namespaces:
          from: Selector
          selector:
            matchLabels:
              mcp-team: team-b
    - name: team-b-mcps
      port: 8081
      protocol: HTTP
      hostname: '*.team-b.mcp.local'
      allowedRoutes:
        namespaces:
          from: Selector
          selector:
            matchLabels:
              mcp-team: team-b
